<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/settings_timeout"
            android:textColor="@color/on_surface" android:textSize="14sp"
            android:layout_marginBottom="4dp"/>
        <EditText android:id="@+id/settingsTimeout"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:inputType="number" android:singleLine="true"
            android:textColor="@color/on_surface"
            android:layout_marginBottom="12dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/settings_body_limit"
            android:textColor="@color/on_surface" android:textSize="14sp"
            android:layout_marginBottom="4dp"/>
        <EditText android:id="@+id/settingsBodyLimit"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:inputType="number" android:singleLine="true"
            android:textColor="@color/on_surface"
            android:layout_marginBottom="12dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/settings_user_agent"
            android:textColor="@color/on_surface" android:textSize="14sp"
            android:layout_marginBottom="4dp"/>
        <EditText android:id="@+id/settingsUserAgent"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:singleLine="true"
            android:textColor="@color/on_surface"
            android:layout_marginBottom="12dp"/>

        <CheckBox android:id="@+id/settingsPrettyJson"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="@string/settings_json_pretty"
            android:textColor="@color/on_surface"
            android:layout_marginBottom="8dp"/>

        <CheckBox android:id="@+id/settingsDisableScreenshots"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="@string/settings_disable_screenshots"
            android:textColor="@color/on_surface"
            android:layout_marginBottom="8dp"/>

        <CheckBox android:id="@+id/settingsBiometric"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="@string/settings_biometric_lock"
            android:textColor="@color/on_surface"
            android:layout_marginBottom="12dp"/>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/divider" android:layout_marginBottom="8dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="In-App Request Options (Repeater only)"
            android:textColor="@color/primary" android:textSize="13sp"
            android:textStyle="bold" android:layout_marginBottom="8dp"/>

        <CheckBox android:id="@+id/settingsSelfSigned"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="@string/settings_accept_self_signed"
            android:textColor="@color/on_surface"
            android:layout_marginBottom="8dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/settings_external_proxy_label"
            android:textColor="@color/on_surface" android:textSize="14sp"
            android:layout_marginBottom="4dp"/>
        <EditText android:id="@+id/settingsExternalProxy"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:hint="http://192.168.1.5:8080"
            android:singleLine="true"
            android:inputType="textUri"
            android:textColor="@color/on_surface"
            android:textColorHint="@color/text_secondary"
            android:layout_marginBottom="12dp"/>

        <Button android:id="@+id/btnSaveSettings"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:text="@string/btn_save_settings"
            android:layout_marginBottom="8dp"/>

        <Button android:id="@+id/btnClearData"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:text="@string/settings_clear_data"
            android:layout_marginBottom="8dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

        <Button android:id="@+id/btnReviewAgreement"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:text="@string/settings_review_agreement"
            style="@style/Widget.MaterialComponents.Button.TextButton"/>

    </LinearLayout>

</ScrollView>
