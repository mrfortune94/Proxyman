<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/surface"
        app:titleTextColor="@color/on_surface" />

    <!-- TOP HALF: WebView browser -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@color/surface">

        <!-- Browser toolbar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:background="@color/surface_variant"
            android:gravity="center_vertical"
            android:paddingStart="4dp"
            android:paddingEnd="4dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_media_previous"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/cd_btn_back"
                android:tint="@color/on_surface" />

            <ImageButton
                android:id="@+id/btnForward"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_media_next"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/cd_btn_forward"
                android:tint="@color/on_surface" />

            <ImageButton
                android:id="@+id/btnRefresh"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_menu_rotate"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/cd_btn_refresh"
                android:tint="@color/on_surface" />

            <ImageButton
                android:id="@+id/btnScrollUp"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/arrow_up_float"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/cd_btn_scroll_up"
                android:tint="@color/on_surface" />

            <ImageButton
                android:id="@+id/btnScrollDown"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/arrow_down_float"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/cd_btn_scroll_down"
                android:tint="@color/on_surface" />

            <ImageButton
                android:id="@+id/btnFullscreen"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_menu_view"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/cd_btn_fullscreen"
                android:tint="@color/on_surface" />

            <EditText
                android:id="@+id/urlBar"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:hint="@string/browser_url_hint"
                android:inputType="textUri"
                android:imeOptions="actionGo"
                android:singleLine="true"
                android:background="@drawable/url_bar_background"
                android:textColor="@color/on_surface"
                android:textColorHint="@color/text_secondary"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:textSize="13sp" />

        </LinearLayout>

        <ProgressBar
            android:id="@+id/webProgressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:max="100"
            android:visibility="gone"
            android:progressTint="@color/primary" />

        <TextView
            android:id="@+id/currentUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:textColor="@color/text_secondary"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:singleLine="true"
            android:ellipsize="middle" />

        <WebView
            android:id="@+id/webView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

    </LinearLayout>

    <!-- DIVIDER -->
    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@color/primary" />

    <!-- BOTTOM HALF: Inspector tabs -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@color/background">

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/surface"
            app:tabTextColor="@color/text_secondary"
            app:tabSelectedTextColor="@color/primary"
            app:tabIndicatorColor="@color/primary"
            app:tabMode="scrollable" />

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/viewPager"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

    </LinearLayout>

</LinearLayout>
