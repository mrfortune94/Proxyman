<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Required to make HTTP/HTTPS requests from the in-app browser and Repeater -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Required to post the ongoing notification while a capture session is active -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- Required to show system notifications on Android 13+ -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Required to write exported HAR / JSON files to shared storage on Android <10 -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <!-- Required for optional biometric lock on saved projects -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />

    <application
        android:name=".FortunateHtmlApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.FortunateHtml"
        android:networkSecurityConfig="@xml/network_security_config"
        android:usesCleartextTraffic="true">

        <activity
            android:name=".ui.DisclaimerActivity"
            android:exported="true"
            android:theme="@style/Theme.FortunateHtml">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.MainActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden" />

        <activity
            android:name=".ui.BrowserActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden" />

        <activity
            android:name=".ui.TrafficDetailActivity"
            android:exported="false" />

    </application>

</manifest>
